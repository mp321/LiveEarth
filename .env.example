# Server-side secrets for the api/ serverless functions. Copy to `.env.local`
# for `vercel dev` (or run `vercel env pull .env.local` after setting them in
# the Vercel dashboard). NEVER prefix these with VITE_ — Vite inlines VITE_*
# variables into the public client bundle.

# OpenSky Network OAuth2 client credentials (api/flights.js).
# Create at https://opensky-network.org/ → My OpenSky → Account → API Client.
OPENSKY_CLIENT_ID=your-email@example.com-api-client
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# OpenAQ v3 API key (api/airquality.js).
# Free key from https://explore.openaq.org/register
OPENAQ_KEY=your-openaq-api-key
