# Server-side secrets for the api/ serverless functions. Copy to `.env.local`
# for `vercel dev` (or run `vercel env pull .env.local` after setting them in
# the Vercel dashboard). NEVER prefix these with VITE_ — Vite inlines VITE_*
# variables into the public client bundle.

# OpenSky Network OAuth2 client credentials (api/flights.js).
# Create at https://opensky-network.org/ → My OpenSky → Account → API Client.
OPENSKY_CLIENT_ID=your-email@example.com-api-client
OPENSKY_CLIENT_SECRET=your-opensky-client-secret

# OpenAQ v3 API key (api/airquality.js).
# Free key from https://explore.openaq.org/register
OPENAQ_KEY=your-openaq-api-key

# Mapillary access token for Ground View (street-level panoramas).
# Free token (MLY|...) from https://www.mapillary.com/dashboard/developers
#
# Server-side, used by api/ground.js for the nearest-image search so those
# search calls stay out of the public bundle:
MAPILLARY_TOKEN=MLY|your-mapillary-token
#
# The embedded MapillaryJS viewer also needs a token IN THE BROWSER to fetch
# imagery, so this one IS VITE_-prefixed — the documented exception to the rule
# above. Mapillary client tokens are designed to be publishable, and the same
# MLY|... value works for both. OPTIONAL: without it Ground View still finds
# coverage but degrades to a keyless Google Street View link-out instead of the
# embedded panorama.
VITE_MAPILLARY_TOKEN=MLY|your-mapillary-token
